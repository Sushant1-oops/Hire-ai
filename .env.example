# ==================== DATABASE CONFIGURATION ====================
# SQLite (Development - Default)
DATABASE_URL=sqlite:///./ai_hr_saas.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_hr_saas

# ==================== OLLAMA LLM CONFIGURATION ====================
OLLAMA_API_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b

# ==================== AUTHENTICATION ====================
# IMPORTANT: Change this to a strong random string in production!
SECRET_KEY=your-super-secret-key-change-this-in-production

# ==================== SERVER CONFIGURATION ====================
PORT=8000
WORKERS=4
ENV=development  # development | production

# ==================== FRONTEND CONFIGURATION ====================
API_BASE_URL=http://localhost:8000
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ==================== LOGGING ====================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# ==================== CORS CONFIGURATION ====================
# For production, be specific with allowed origins
ALLOWED_ORIGINS=["http://localhost:8501", "http://localhost:3000"]

# ==================== OPTIONAL: REDIS CACHING ====================
# REDIS_URL=redis://localhost:6379/0

# ==================== OPTIONAL: EMAIL SERVICE ====================
# For sending actual emails (not AI-generated)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SENDER_EMAIL=noreply@aihr.com

# ==================== OPTIONAL: AWS S3 (File Storage) ====================
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_S3_BUCKET=ai-hr-resumes
# AWS_REGION=us-east-1
