# Environment Template
# Copy this file to create .env.local and update with your values

# API Configuration
VITE_API_URL=http://localhost:8000/api

# App Configuration
VITE_APP_NAME=AI HR Assistant
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ADVANCED_SEARCH=true
